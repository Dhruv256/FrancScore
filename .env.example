# APP (public, safe for browser)
NEXT_PUBLIC_APP_NAME="FrancScore"
NEXT_PUBLIC_APP_URL="https://your-production-domain.example"
NEXT_PUBLIC_APP_ENV="production"

# SUPABASE (public anon values are safe for browser)
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project-url.example"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# SUPABASE (server-only)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
DATABASE_URL="your-pooled-postgres-connection-string"
DIRECT_URL="your-direct-postgres-connection-string"

# NVIDIA (server-only)
NVIDIA_API_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_AI_TIMEOUT_MS="45000"
NVIDIA_MAIN_MODEL="your-main-nvidia-model"
NVIDIA_IMPORT_CLEANUP_MODEL="moonshotai/kimi-k2.6"
NVIDIA_VOCAB_GENERATION_MODEL="moonshotai/kimi-k2.6"
NVIDIA_VOCAB_FALLBACK_MODEL="meta/llama-4-maverick-17b-128e-instruct"
NVIDIA_LISTENING_SCRIPT_MODEL="moonshotai/kimi-k2-thinking"
NVIDIA_LISTENING_FALLBACK_MODEL="meta/llama-4-maverick-17b-128e-instruct"
NVIDIA_PDF_PROCESSING_MODEL="moonshotai/kimi-k2.6"
NVIDIA_PDF_FALLBACK_MODEL="meta/llama-4-maverick-17b-128e-instruct"
NVIDIA_MAIN_API_KEY="your-main-model-api-key"
NVIDIA_RERANK_MODEL="your-rerank-nvidia-model"
NVIDIA_RERANK_API_KEY="your-rerank-api-key"
NVIDIA_SAFETY_MODEL="your-safety-nvidia-model"
NVIDIA_SAFETY_API_KEY="your-safety-api-key"
NVIDIA_STT_MODEL="your-stt-nvidia-model"
NVIDIA_STT_API_KEY="your-stt-api-key"

# AI feature flags (server-only)
AI_ENABLE_WRITING_EVALUATION="true"
AI_ENABLE_SPEAKING_EVALUATION="true"
AI_ENABLE_STUDY_PLAN="true"
AI_ENABLE_ADMIN_GENERATION="true"
AI_ENABLE_RERANKING="true"
AI_ENABLE_SAFETY_CHECK="true"
AI_ENABLE_STT="false"
AI_VOCAB_GENERATION_ENABLED="true"
DAILY_AI_VOCAB_COUNT="50"
LISTENING_TTS_ENABLED="true"
PDF_PROCESSING_ENABLED="true"
PDF_BOOK_FEATURE_ENABLED="true"
PDF_CHUNK_SIZE="5000"
PDF_CHUNK_OVERLAP="500"
PDF_MAX_PAGES_PER_UPLOAD="500"
PDF_CHUNKS_PER_PROCESSING_STEP="1"
JOB_POLL_INTERVAL_MS="2500"
VOCAB_GENERATION_BATCH_SIZE="10"

# AI usage limits (server-only)
FREE_DAILY_WRITING_EVALUATIONS="1"
FREE_DAILY_SPEAKING_EVALUATIONS="1"
FREE_DAILY_STUDY_PLANS="1"
FREE_DAILY_AI_EXPLANATIONS="5"
PRO_DAILY_WRITING_EVALUATIONS="50"
PRO_DAILY_SPEAKING_EVALUATIONS="50"
PRO_DAILY_STUDY_PLANS="10"
PRO_DAILY_AI_EXPLANATIONS="200"
AI_RATE_LIMIT_WINDOW_SECONDS="86400"
AI_RATE_LIMIT_FREE_DAILY="10"
AI_RATE_LIMIT_PRO_DAILY="200"

# Supabase Storage bucket names (server-only)
SUPABASE_LISTENING_AUDIO_BUCKET="your-listening-audio-bucket"
SUPABASE_SPEAKING_AUDIO_BUCKET="your-speaking-audio-bucket"
SUPABASE_USER_UPLOADS_BUCKET="your-user-uploads-bucket"
SUPABASE_PDF_IMPORTS_BUCKET="study-sources"

# Auth / security (server-only)
SESSION_SECRET="generate-a-long-random-secret-at-least-32-chars"
CRON_SECRET=""
ADMIN_EMAILS="your-admin-email@example.com"
ALLOWED_EMAIL_DOMAINS=""

# Payments (optional)
PAYMENTS_ENABLED="false"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Email (optional)
EMAIL_ENABLED="false"
EMAIL_FROM="FrancScore <noreply@your-production-domain.example>"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""

# Analytics (public)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://your-posthog-host.example"
