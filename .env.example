# =========================================================
# APP (Public — safe to expose to browser)
# =========================================================

NEXT_PUBLIC_APP_NAME="FrancScore"
NEXT_PUBLIC_APP_URL="https://francscore.app"
NEXT_PUBLIC_APP_ENV="production"

# =========================================================
# SUPABASE (NEXT_PUBLIC_ prefix = safe for browser)
# =========================================================

NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# SERVER-ONLY — never expose these to the browser or NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
DATABASE_URL="postgresql://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# =========================================================
# NVIDIA BUILD / NIM API  — SERVER-ONLY
# =========================================================

# Map to NVIDIA_BUILD_API_KEY in code (env.ts reads this name)
NVIDIA_BUILD_API_KEY="your-nvidia-build-api-key"
NVIDIA_BUILD_API_BASE_URL="https://integrate.api.nvidia.com"
NVIDIA_BUILD_API_TIMEOUT_MS="45000"

# =========================================================
# AI USAGE LIMITS (server-only)
# =========================================================

FREE_DAILY_WRITING_EVALUATIONS="1"
FREE_DAILY_SPEAKING_EVALUATIONS="1"
FREE_DAILY_STUDY_PLANS="1"
FREE_DAILY_AI_EXPLANATIONS="5"

PRO_DAILY_WRITING_EVALUATIONS="50"
PRO_DAILY_SPEAKING_EVALUATIONS="50"
PRO_DAILY_STUDY_PLANS="10"
PRO_DAILY_AI_EXPLANATIONS="200"

# Rate limiting
AI_RATE_LIMIT_WINDOW_SECONDS="86400"
AI_RATE_LIMIT_FREE_DAILY="10"
AI_RATE_LIMIT_PRO_DAILY="200"

# =========================================================
# AUTH / SECURITY (server-only)
# =========================================================

SESSION_SECRET="generate-a-long-random-secret-at-least-32-chars"
ADMIN_EMAILS="your-email@example.com"
ALLOWED_EMAIL_DOMAINS=""

# =========================================================
# SUPABASE STORAGE BUCKETS (server-only)
# =========================================================

SUPABASE_LISTENING_AUDIO_BUCKET="listening-audio"
SUPABASE_SPEAKING_AUDIO_BUCKET="speaking-audio"
SUPABASE_USER_UPLOADS_BUCKET="user-uploads"

# =========================================================
# PAYMENTS — FUTURE (server-only)
# =========================================================

PAYMENTS_ENABLED="false"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# =========================================================
# EMAIL — FUTURE (server-only)
# =========================================================

EMAIL_ENABLED="false"
EMAIL_FROM="FrancScore <noreply@francscore.app>"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"

# =========================================================
# ANALYTICS (Public — safe to expose to browser)
# =========================================================

NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
